# Mini-NAS configuration
# Copy this file to .env and fill in your values
# .env is git-ignored - safe to put credentials here

# === REQUIRED ===

# Path to your Eirik (or memory) folder on host machine
# Windows: C:/Users/yourname/Desktop/Eirik
# macOS:   /Users/yourname/Desktop/Eirik
# Linux:   /home/yourname/Eirik
EIRIK_PATH=

# Cloud Supabase credentials (from your Supabase project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=sb_publishable_YOUR_ANON_KEY

# === OPTIONAL (defaults shown) ===

# Local data + scripts paths (relative to docker-compose.yml)
DATA_PATH=./data
SCRIPTS_PATH=./scripts
BACKUP_PATH=./backups

# Postgres credentials (change for production!)
POSTGRES_USER=forestsense
POSTGRES_PASSWORD=forestsense_dev_2026
POSTGRES_DB=forestsense
POSTGRES_PORT=5432

# pgAdmin credentials (change for production!)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=forestsense_dev_2026
PGADMIN_PORT=5050

# Sync intervals (seconds)
SUPABASE_SYNC_INTERVAL=900       # 15 min
MEMORY_SYNC_INTERVAL=3600        # 1 hour
MAX_FILE_SIZE=1048576            # 1 MB

# ZIP backup retention (number of backups to keep)
KEEP_BACKUPS=30
